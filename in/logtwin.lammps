# ---------------- 冻结参考盒子长度 (用于计算工程应变) ----------------
variable        tmpx equal lx
variable        L0 equal ${tmpx}
variable        L0 equal 40.0934596268475
variable        tmpy equal ly
variable        L1 equal ${tmpy}
variable        L1 equal 96
variable        tmpz equal lz
variable        L2 equal ${tmpz}
variable        L2 equal 40.1973587940096

# ---------------- 冻结参考初始应力 (用于输出相对零应力) ----------------
variable        tmpSx equal c_thermo_press_lmp[1]
variable        S0x equal ${tmpSx}
variable        S0x equal 104.408863541237
variable        tmpSy equal c_thermo_press_lmp[2]
variable        S0y equal ${tmpSy}
variable        S0y equal 1765.59365410235
variable        tmpSz equal c_thermo_press_lmp[3]
variable        S0z equal ${tmpSz}
variable        S0z equal 50.7858384529843

# 重置时间步！这保证了后续的 restart 文件名直接对应压缩步数
reset_timestep  0
run             0
