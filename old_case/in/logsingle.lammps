LAMMPS (29 Sep 2021)
# =========================================================
# BTO 沿 Y 轴压缩脚本 (基于已弛豫的 restart 文件)
# 包含了完整的力场重定义
# 保持了原始的 dump 输出格式和数据平滑输出
#
# 优化点：
# 重新调整了 Nload 和 RSTINT，确保 restart 文件在精确的 0.1% 应变整数点输出
# =========================================================

units           metal
dimension       3
boundary        p p p
atom_style      full
atom_modify     map yes

timestep        0.00005

# ---------------- 用户参数设置 ----------------
variable        RST       string single_relaxed_ready.restart
variable        CASE      string single
variable        TAG       string ${CASE}_ycompress_cont_2pct
variable        TAG       string single_ycompress_cont_2pct

variable        Tstart    equal 5.0
variable        Tstop     equal 5.0
variable        Tdamp     equal 0.10
variable        Pdamp     equal 2.0
variable        Ptarget   equal 0.0

# --- 【关键修改区：精确控制输出节点】 ---
# 目标：总压缩应变为 -2.0% (epsY = -0.02)
# 我们将总步数设为 1,000,000 步，这样每 1,000,000 步对应 2.0% 应变。
# 因此，每 50,000 步正好对应 0.1% 的应变 (0.001)。

variable        Npre      equal 20000       # 压缩前短时间弛豫步数
variable        Nload     equal 1000000     # 压缩过程总步数 (修改为100万步方便计算)
variable        epsY      equal -0.02       # 目标总应变 (-2.0%)
variable        ey_comp   equal v_epsY/(v_Nload*dt) # 计算应变率

variable        THERMOINT equal 1000
variable        DUMPINT   equal 10000

# 【核心参数】：设置 restart 输出间隔为 50000 步
# 因为使用了 reset_timestep 0，输出的文件将是：
# *.50000.restart  对应应变 -0.1%
# *.100000.restart 对应应变 -0.2%
# *.150000.restart 对应应变 -0.3%
# ... 以此类推，直到 *.1000000.restart (-2.0%)
variable        RSTINT    equal 50000
# ----------------------------------------

variable        OUTINST   string ${CASE}_ss_y_inst_2pct_cont.txt
variable        OUTINST   string single_ss_y_inst_2pct_cont.txt
variable        OUTAVG1   string ${CASE}_ss_y_avg_2pct_cont.txt
variable        OUTAVG1   string single_ss_y_avg_2pct_cont.txt
variable        OUTAVG2   string ${CASE}_ss_y_avg_2pct_cont_smooth.txt
variable        OUTAVG2   string single_ss_y_avg_2pct_cont_smooth.txt

# ---------------- 读取弛豫好的 restart 文件 ----------------
read_restart    ${RST}
read_restart    single_relaxed_ready.restart
Reading restart file ...
  restart file = 29 Sep 2021, LAMMPS = 29 Sep 2021
  restoring atom style full from restart
  triclinic box = (-0.033107229 0.0000000 -0.073459944) to (40.043107 96.010000 40.083460) with tilt (0.0000000 0.0000000 0.0000000)
  2 by 8 by 2 MPI processor grid
  restoring pair style born/coul/long/cs from restart
  restoring bond style class2 from restart
  24000 atoms
  12000 bonds
Finding 1-2 1-3 1-4 neighbors ...
  special bond factors lj:    0        0        0       
  special bond factors coul:  0        1        1       
     1 = max # of 1-2 neighbors
     0 = max # of 1-3 neighbors
     0 = max # of 1-4 neighbors
     1 = max # of special neighbors
  special bonds CPU = 0.002 seconds
  read_restart CPU = 0.017 seconds
fix             csinfo all property/atom i_CSID
Resetting peratom fix info from restart file:
  fix style: property/atom, fix ID: csinfo

# ---------------- 分组设定 (Groups) ----------------
group           Bacore    type 1
2400 atoms in group Bacore
group           Bashell   type 2
2400 atoms in group Bashell
group           Ticore    type 3
2400 atoms in group Ticore
group           Tishell   type 4
2400 atoms in group Tishell
group           Ocore     type 5
7200 atoms in group Ocore
group           Oshell    type 6
7200 atoms in group Oshell
group           cores     type 1 3 5
12000 atoms in group cores
group           shells    type 2 4 6
12000 atoms in group shells
group           BTO       type 1 2 3 4 5 6
24000 atoms in group BTO

# ---------------- 邻居列表设置 ----------------
neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes
comm_style      brick
comm_modify     vel yes cutoff 15.0

# ---------------- 力场重定义 (从 restart 续算必须包含) ----------------
pair_style      born/coul/long/cs 8.0 10.0
kspace_style    pppm 1.0e-5
pair_coeff      * * 0.0 1.000 0.0 0.0 0.0
pair_coeff      2 6 1568.42 0.3471 0.0 0.0 0.0
pair_coeff      4 6 3139.49 0.2549 0.0 0.0 0.0
pair_coeff      6 6 2571.97 0.3554 0.0 528.65 0.0
pair_modify     table 0

bond_style      class2
bond_coeff      1 0.0 154.915 0.0 0.0
bond_coeff      2 0.0 163.455 0.0 0.0
bond_coeff      3 0.0 23.185 0.0 289.8716667

special_bonds   coul 0.0 1.0 1.0

# ---------------- 计算项 (Computes) ----------------
compute         Tcs all temp/cs cores shells
compute         thermo_press_lmp all pressure Tcs
compute         dis all displace/atom
Resetting peratom fix info from restart file:
  fix style: STORE, fix ID: dis_COMPUTE_STORE
compute         myKE all ke/atom
compute         myPE all pe/atom
compute         mystress all stress/atom NULL
compute         COM BTO com
compute         UNWRAP BTO property/atom xu yu zu

variable        Mise atom sqrt(0.5*((c_mystress[1]-c_mystress[2])^2+(c_mystress[2]-c_mystress[3])^2+(c_mystress[3]-c_mystress[1])^2)+3.0*((c_mystress[4])^2+(c_mystress[5])^2+(c_mystress[6])^2))
variable        comx equal c_COM[1]
variable        comy equal c_COM[2]
variable        comz equal c_COM[3]
variable        mux atom q*(c_UNWRAP[1]-v_comx)
variable        muy atom q*(c_UNWRAP[2]-v_comy)
variable        muz atom q*(c_UNWRAP[3]-v_comz)
compute         MUX BTO reduce sum v_mux
compute         MUY BTO reduce sum v_muy
compute         MUZ BTO reduce sum v_muz

variable        conv equal 1602.176634
variable        Px equal v_conv*c_MUX/vol
variable        Py equal v_conv*c_MUY/vol
variable        Pz equal v_conv*c_MUZ/vol

thermo          ${THERMOINT}
thermo          1000
thermo_style    custom step time temp press pxx pyy pzz v_Px v_Py v_Pz lx ly lz xy xz yz
thermo_modify   temp Tcs press thermo_press_lmp lost error

run             0
