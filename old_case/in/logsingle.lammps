# ---------------- 压缩前短时间预弛豫 (NPT) ----------------
fix             fmom2 all momentum 1000 linear 1 1 1
fix             npt_eq all npt temp ${Tstart} ${Tstop} ${Tdamp} x ${Ptarget} ${Ptarget} ${Pdamp} z ${Ptarget} ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 ${Tstop} ${Tdamp} x ${Ptarget} ${Ptarget} ${Pdamp} z ${Ptarget} ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 ${Tdamp} x ${Ptarget} ${Ptarget} ${Pdamp} z ${Ptarget} ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 0.1 x ${Ptarget} ${Ptarget} ${Pdamp} z ${Ptarget} ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 0.1 x 0 ${Ptarget} ${Pdamp} z ${Ptarget} ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 0.1 x 0 0 ${Pdamp} z ${Ptarget} ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 0.1 x 0 0 2 z ${Ptarget} ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 0.1 x 0 0 2 z 0 ${Ptarget} ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 0.1 x 0 0 2 z 0 0 ${Pdamp} drag 1
fix             npt_eq all npt temp 5 5 0.1 x 0 0 2 z 0 0 2 drag 1
fix_modify      npt_eq temp Tcs press thermo_press_lmp

run             ${Npre}
run             20000
